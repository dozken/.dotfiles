  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "synergy-agents": {
      "source": {
        "source": "github",
        "repo": "Presight-AI/synergy-agents"
      }
    }
  },
  "effortLevel": "high",
