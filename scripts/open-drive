#!/bin/bash

diskutil list
echo "NTFS partitions found:"
diskutil list | grep -i "ntfs"

read -p "Enter the disk identifier to mount (e.g., disk2s1): " selected_disk

if [ -z "$selected_disk" ]; then
	echo "Invalid disk identifier. Exiting."
	exit 1
fi

# Unmount with diskutil
sudo diskutil unmount force "/dev/${selected_disk}"

# Get disk name safely
selected_disk_name=$(diskutil info "/dev/${selected_disk}" | awk -F: '/Volume Name/ {sub(/^ +/, "", $2); print $2}')
[ -z "$selected_disk_name" ] && selected_disk_name="NTFS_Drive"

# Mount point
mount_point="$HOME/${selected_disk_name}_ntfs"
mkdir -p "$mount_point"

# Mount using ntfs-3g
echo "Mounting /dev/${selected_disk} to $mount_point ..."
sudo ntfs-3g /dev/$selected_disk "$mount_point" -o local -o allow_other -o auto_xattr -o auto_cache

if [ $? -eq 0 ]; then
	open "$mount_point"
	echo "Mounted successfully at $mount_point"
else
	echo "Failed to mount. Check if ntfs-3g and macFUSE are installed."
	exit 1
fi

read -n 1 -s -r -p "Press 'q' to unmount and eject the drive..."

if [ "$REPLY" == "q" ]; then
	sudo diskutil unmount force "$mount_point"
	diskutil eject "/dev/${selected_disk}"
	echo "Drive unmounted and ejected."
fi
