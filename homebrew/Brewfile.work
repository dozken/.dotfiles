# WORK profile (machine PAI-LQJ4T7WW6V). Installed on top of base Brewfile.
# Vantage: java/maven backend, gitlab, mobile, cloud.

tap "sdkman/tap"
tap "minio/stable"

# ── JVM / build ──────────────────────────────────────────────────────
brew "sdkman/tap/sdkman-cli"       # java SDK manager (sourced by .zshrc)
# maven, gradle → managed by mise (see profile .tool-versions). gradle also via ./gradlew wrapper.

# ── GitLab / CI ──────────────────────────────────────────────────────
brew "glab"
brew "gitlab-runner"
brew "act"                         # run GitHub Actions locally

# ── Cloud / infra ────────────────────────────────────────────────────
brew "azure-cli"
brew "flyctl"
brew "minio/stable/mc"             # minio/S3 client
brew "mkcert"                      # local TLS certs
brew "nss"

# ── Databases ────────────────────────────────────────────────────────
brew "libpq"                       # psql client lib
# postgresql@14 removed (deprecated); use mise/orbstack container for a local server

# ── Mobile ───────────────────────────────────────────────────────────
brew "fastlane"
brew "cocoapods"
brew "scrcpy"

# ── Casks ────────────────────────────────────────────────────────────
cask "caffeine"
cask "figma"
cask "intellij-idea"
cask "insomnia"
cask "android-commandlinetools"
cask "android-platform-tools"
cask "gcloud-cli"
