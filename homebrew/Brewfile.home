# HOME profile. Installed on top of base Brewfile.
# Personal machine — media, extra runtimes, misc.

tap "oven-sh/bun"

# ── Extra runtimes / package managers ────────────────────────────────
# go, python, rust, node → managed by mise. yarn dropped (bun-only).
brew "rustup"                      # toolchain manager (mise's rust symlinks to it)
brew "oven-sh/bun/bun"

# ── CLI extras ───────────────────────────────────────────────────────
brew "dust"
brew "hyperfine"
brew "pandoc"
brew "tailscale", restart_service: :changed

# ── AI / media ───────────────────────────────────────────────────────
brew "ollama"
brew "gemini-cli"

# ── Casks ────────────────────────────────────────────────────────────
cask "antigravity"
cask "qbittorrent"
cask "steam"
cask "vlc"
